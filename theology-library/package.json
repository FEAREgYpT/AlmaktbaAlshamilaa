{
  "name": "theology-library",
  "version": "1.0.0",
  "description": "Sovereign Theology Library",
  "main": "dist-electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"npm run electron-dev\"",
    "electron-dev": "npm run electronDevBuild && electron .",
    "build": "vite build && npm run electronDevBuild",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "electronDevBuild": "tsc -p tsconfig.electron.json --noEmitOnError false"
    "electron-dev": "tsc -p tsconfig.electron.json && electron .",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.3",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "vite": "^5.1.0",
    "vite-plugin-electron": "^0.28.4",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.1",
    "@tanstack/react-query": "^5.17.19",
    "axios": "^1.6.7",
    "zustand": "^4.5.0",
    "yet-another-react-lightbox": "^3.15.6",
    "@tiptap/react": "^2.2.4",
    "@tiptap/starter-kit": "^2.2.4",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.57",
    "@types/react-dom": "^18.2.19",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.18",
    "tsx": "^4.7.1"
  },
  "build": {
    "appId": "com.theologylib.sovereign",
    "productName": "Sovereign Theology Library",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "server/**",
      "electron/**",
      "package.json",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  }
}
"build": {
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "package.json"
  ]
}

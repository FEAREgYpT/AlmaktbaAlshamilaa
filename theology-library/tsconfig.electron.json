{
  "compilerOptions": {
    "target": "ES2020",
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist-electron",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "noEmitOnError": false
  },
  "include": [
    "electron",
    "server"
  ]
}
    "types": ["node"]
  },
  "include": ["electron/**/*"]
}
